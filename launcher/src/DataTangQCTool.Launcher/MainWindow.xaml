<Window x:Class="DataTangQCTool.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数据堂质检工具启动器" Height="460" Width="760"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="数据堂质检工具" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="首次联网安装运行库，后续直接使用本地缓存" Margin="0,6,0,20" Foreground="#666" />
        </StackPanel>

        <Border Grid.Row="1" Background="#F3F6FA" CornerRadius="8" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="缓存位置：" VerticalAlignment="Center" FontWeight="SemiBold" />
                <TextBlock x:Name="CacheRootText" Grid.Column="1" Text="尚未选择" Margin="8,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <Button x:Name="ChangeCacheButton" Grid.Column="2" Content="更改位置" Click="ChangeCacheButton_Click" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,22,0,0">
            <TextBlock x:Name="StageText" Text="准备启动……" FontSize="17" FontWeight="SemiBold" />
            <ProgressBar x:Name="ProgressBar" Height="18" Margin="0,12,0,0" Minimum="0" Maximum="100" IsIndeterminate="True" />
            <TextBlock x:Name="DetailText" Text="正在检查本地环境" Margin="0,8,0,0" Foreground="#666" />
        </StackPanel>

        <TextBox x:Name="LogPreview" Grid.Row="3" Margin="0,18,0,8" IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Background="#FAFAFA" BorderBrush="#DDD" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OpenLogButton" Content="打开日志" Click="OpenLogButton_Click" />
            <Button x:Name="RetryButton" Content="重试" Click="RetryButton_Click" Visibility="Collapsed" />
            <Button x:Name="CancelButton" Content="取消" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
